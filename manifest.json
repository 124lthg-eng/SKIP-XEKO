{
  "manifest_version": 3,
  "name": "YouTube Segment Skipper",
  "version": "1.0.0",
  "description": "Automatically skips configured segments in specific YouTube videos.",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
